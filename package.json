{
  "name": "pro-life",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:sourcemap": "vite build --sourcemap",
    "ci:check": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run test:a11y && npm run build && npm run perf:budget",
    "preview:e2e": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "npm run lint:js && npm run lint:styles",
    "lint:js": "eslint .",
    "lint:styles": "stylelint \"src/**/*.{css,scss}\"",
    "lint:fix": "npm run lint:js -- --fix && npm run lint:styles -- --fix",
    "test": "vitest run --exclude \"src/**/*.a11y.test.jsx\"",
    "test:watch": "vitest",
    "test:a11y": "vitest run src/a11y/app.a11y.test.jsx",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "audit:deps": "npm audit --omit=dev --audit-level=high",
    "perf:budget": "node ./scripts/check-performance-budget.mjs",
    "preview": "vite preview",
    "seo:validate": "./scripts/validate-seo.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md,html,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "@sentry/react": "^10.46.0",
    "@tanstack/react-query": "^5.95.2",
    "bootstrap": "^5.3.8",
    "i18next": "^26.0.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^17.0.1",
    "react-router-dom": "^7.13.2",
    "web-vitals": "^5.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "stylelint": "^17.6.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.1",
    "vitest": "^4.1.2",
    "vitest-axe": "^0.1.0"
  }
}
