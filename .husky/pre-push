upstream="$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || true)"

if [ -n "$upstream" ]; then
  lint_from="$upstream"
else
  origin_head_ref="$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null || true)"

  if [ -n "$origin_head_ref" ]; then
    lint_from="$(git merge-base HEAD "$origin_head_ref")"
  elif git show-ref --verify --quiet refs/remotes/origin/main; then
    lint_from="$(git merge-base HEAD refs/remotes/origin/main)"
  elif git show-ref --verify --quiet refs/remotes/origin/development; then
    lint_from="$(git merge-base HEAD refs/remotes/origin/development)"
  else
    lint_from="$(git rev-list --max-parents=0 HEAD | tail -n 1)"
  fi
fi

npx --no -- commitlint --from "$lint_from" --to HEAD

npm run ci:check
